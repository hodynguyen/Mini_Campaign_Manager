# Hody workflow — local-only state (commit the rest of .hody/)
.hody/tracker.db
.hody/tracker.db-shm
.hody/tracker.db-wal

# Node
node_modules/
dist/
build/
.turbo/
coverage/
*.tsbuildinfo

# Workspace artifacts (parent dist/ + coverage/ already cover these,
# kept explicit for clarity when grepping)
apps/*/dist/
apps/*/coverage/

# Yarn berry — guard against accidental v2+ usage; this repo is yarn 1 classic
.yarn/

# Local Postgres data (in case `docker compose up` is run with a bind mount)
pgdata/

# Env
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editors / OS
.DS_Store
.idea/
.vscode/
*.swp

# Personal documents — never commit to a public submission repo
*.pdf
NguyenThanhDat_*.pdf
jd.pdf
