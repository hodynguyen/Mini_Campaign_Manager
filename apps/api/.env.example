# Copy to .env (gitignored) before running.
# Mini Campaign Manager — API environment variables.

# HTTP
PORT=4000
NODE_ENV=development

# Database (matches docker-compose service defaults; devops authors compose file)
DATABASE_URL=postgresql://campaign:campaign@localhost:5432/campaign

# Test database — REQUIRED when NODE_ENV=test (env loader exits otherwise).
# Tests truncate all tables; pointing at the dev DB would wipe local data.
DATABASE_URL_TEST=postgresql://campaign:campaign@localhost:5432/campaign_test

# Auth — replace with a long random string before deploying anywhere.
# Production requires >=32 chars (enforced by env.ts superRefine).
JWT_SECRET=change-me-please-use-32-chars-min-12345

# JWT expiry — accepts the `vercel/ms` short forms ('24h', '15m', '900s', etc.).
# 24h is the F2 default per ADR-011 (no refresh tokens).
JWT_EXPIRES_IN=24h

# CORS — CSV of allowed origins. Vite dev server is :5173 by default.
# Multiple origins supported: CORS_ORIGINS=http://localhost:5173,https://app.example.com
CORS_ORIGINS=http://localhost:5173

# F4 — async send simulation knobs.
# SEND_SUCCESS_RATE: per-recipient probability of `sent` (vs `failed`).
# Float in [0, 1]; default 0.8 matches the spec's 80/20 split. Tests may
# override per-spec to 1.0 (all-sent) or 0.0 (all-failed) for determinism.
SEND_SUCCESS_RATE=0.8

# SEND_WORKER_DELAY_MS: optional artificial latency injected before the
# worker flips campaign.status from 'sending' to 'sent'. Non-negative
# integer milliseconds; default 0 = no delay. Lets integration tests
# observe the `sending` intermediate state via polling if needed.
SEND_WORKER_DELAY_MS=0
